# Copie para .env e ajuste os valores.
# O Makefile inclui .env (se existir) e exporta PORT.

# Endereço completo do servidor (opcional). Se vazio, usa net.JoinHostPort("", PORT).
# Exemplo: ADDR=:9090 ou ADDR=127.0.0.1:9090
ADDR=

# Porta HTTP quando ADDR não está definido (padrão no código: 3000)
PORT=3000

# Data de referência para juros (YYYY-MM-DD), UTC. Vazio = time.Now().UTC() no startup.
# Útil para reproduzir os números do documento de teste: REFERENCE_DATE=2024-05-10
REFERENCE_DATE=

# Nível de log: deixe vazio ou qualquer valor ≠ DEBUG para INFO.
# Use DEBUG para mensagens de debug no slog.
LOG_LEVEL=

# true = insere um provider mock que falha no início da cadeia (demo de fallback).
# Útil com: make demo-fallback
ENABLE_MOCK_FAILING=

# true = primeiro provedor simula lentidão até estourar o timeout da tentativa (demo de timeout).
# Útil com: make demo-timeout. Se ENABLE_MOCK_FAILING também for true, o modo slow tem precedência.
ENABLE_MOCK_SLOW=

# Tentativas por provedor antes de passar ao próximo (inteiro >= 1; padrão 1 = sem retry extra).
PROVIDER_MAX_ATTEMPTS=

# Pausa em ms entre tentativas no mesmo provedor (0 = desligado).
PROVIDER_RETRY_BACKOFF_MS=
